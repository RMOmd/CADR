# CoinMarketCap Skill Hub / MCP-first configuration
CMC_SKILL_HUB_API_KEY=your_cmc_skill_hub_api_key_here
CMC_SKILL_HUB_URL=https://mcp.coinmarketcap.com/skill-hub/stream
CMC_SKILL_HUB_TOOL_TIMEOUT_SEC=300

# Local dashboard
CADR_DASHBOARD_DB_PATH=log/cadr_dashboard.db
CADR_DASHBOARD_HOST=127.0.0.1
CADR_DASHBOARD_PORT=8010
CADR_MONITOR_ENABLED=1
CADR_MONITOR_INTERVAL_SEC=300
CADR_MONITOR_LOOKBACK_DAYS=90
CADR_MONITOR_POLL_SEC=10
CADR_FORECAST_HORIZON_HOURS=24
CADR_FORECAST_EXPORT_PATH=log/cadr_forecasts.json

# Optional REST fallback configuration
CMC_API_KEY=your_coinmarketcap_pro_api_key_here
CMC_API_BASE_URL=https://pro-api.coinmarketcap.com
CMC_API_TIMEOUT_SEC=30
CMC_API_RETRY_COUNT=3
CMC_API_RETRY_BACKOFF_SEC=1.5
CMC_API_MIN_INTERVAL_SEC=1.2
CMC_SKILL_HUB_RETRY_COUNT=2
CMC_SKILL_HUB_RETRY_BACKOFF_SEC=2.0

# Backtest realism
BACKTEST_FEE_BPS_PER_LEG=6
BACKTEST_SLIPPAGE_BPS_PER_LEG=4
BACKTEST_BORROW_BPS_DAILY=1.5
